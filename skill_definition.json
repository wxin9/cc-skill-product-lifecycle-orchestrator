{
  "name": "product-lifecycle-orchestrator",
  "version": "2.3",
  "description": "Product Lifecycle Orchestrator：先识别用户意图，再编排 PRD/UED/Tech/Test Specs、Lifecycle Graph、影响分析和迭代 gate 的产品生命周期 skill",
  "author": "Claude Code",
  "created_at": "2026-04-04",
  "updated_at": "2026-04-29",
  "tier": "stateful",
  "trigger_keywords": [
    "产品设计", "PRD", "需求文档", "技术架构", "迭代规划",
    "Product Lifecycle Orchestrator", "product-lifecycle-orchestrator", "产品管理",
    "从零开始做产品", "迭代门控", "ADR", "velocity追踪", "DoD", "Sprint Review",
    "test graph", "dependency review", "test knowledge graph", "维度",
    "machine spec", "Lifecycle Graph", "Product Spec", "Tech Spec", "Test Spec"
  ],
  "commands": {
    "run": "python -m scripts orchestrator run --user-input \"<input>\"",
    "resume": "python -m scripts orchestrator resume --from-phase <phase-id>",
    "status": "python -m scripts orchestrator status",
    "cancel": "python -m scripts orchestrator cancel",
    "rollback_list": "python -m scripts orchestrator rollback --list",
    "rollback_to": "python -m scripts orchestrator rollback --rollback-point-id <id>"
  },
  "valid_intents": [
    "auto", "new-product", "from-scratch", "new-feature",
    "prd-change", "arch-change", "test-change",
    "new-iteration", "continue-iter",
    "code-change", "test-failure", "bug-fix", "gap",
    "resume", "status"
  ],
  "model_compatibility": {
    "claude-opus-4-6": "full",
    "claude-sonnet-4-6": "full",
    "claude-haiku-4-5": "partial"
  },
  "dependencies": {
    "python": ">=3.8",
    "stdlib_only": true
  }
}
